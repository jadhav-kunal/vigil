# ============================================================================
#  Vigil configuration. Copy to `.env` and fill what you need.
#  EVERYTHING below is optional except the upstream provider base URL.
#  Absent key => that capability is silently skipped (no error, no code change).
# ============================================================================

# --- Core proxy -------------------------------------------------------------
VIGIL_HOST=0.0.0.0
VIGIL_PORT=8765
# DEBUG | INFO | WARNING | ERROR
VIGIL_LOG_LEVEL=INFO
# Upstream LLM the proxy forwards to. The CALLER's API key is passed through
# unchanged in the Authorization header; Vigil never stores it.
OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic upstream (used when an Anthropic-format request is detected)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Store ------------------------------------------------------------------
# SQLite path used in local mode (default). If REDIS_URL is set, Redis is used
# for pub/sub + persistence + (optionally) the RedisVL vector backend.
VIGIL_DB_PATH=vigil.db
# REDIS_URL=redis://localhost:6379/0

# --- Watchdog thresholds (see spec 4.2) ------------------------------------
VIGIL_WINDOW=5
VIGIL_TRIP_STREAK=3
VIGIL_THETA_SIM=0.85
VIGIL_THETA_ENT=0.30
VIGIL_GOAL_JUDGE_CADENCE=5
VIGIL_RECOVERY_STEPS=3
# normal | polling  (polling skips cosine detection)
VIGIL_SESSION_MODE=normal

# --- Goal judge / governor LLM classifier (optional) ------------------------
# provider: "openai" (any OpenAI-compatible endpoint) or "anthropic" (Claude).
# VIGIL_JUDGE_PROVIDER=openai
# VIGIL_JUDGE_BASE_URL=https://api.openai.com/v1
# VIGIL_JUDGE_API_KEY=
# VIGIL_JUDGE_MODEL=gpt-4o-mini

# --- Forensics (spec 4.7): content-addressed exchange cache for replay/fork --
# On by default; caches request body + response per step (never the provider
# key) so POST /sessions/{id}/replay and /fork work with zero/one upstream call.
VIGIL_FORENSICS_ENABLED=true

# --- Effort governor (spec 4.6): opt-in per-step model routing --------------
# Off by default. When on, each step is classified and routed to the cheapest
# adequate model (never upgraded past the requested model).
VIGIL_GOVERNOR_ENABLED=false
# Optional JSON override of the provider->tier->model routing map, e.g.
# VIGIL_GOVERNOR_MODEL_MAP={"openai":{"EXTRACTION":"gpt-4.1-nano"}}
# VIGIL_GOVERNOR_MODEL_MAP=

# --- Compression Layer 1 (always-on, free, structural — see spec 4.5) -------
VIGIL_COMPRESS_ENABLED=true
# Truncate a single tool output above this many bytes (head+tail kept).
VIGIL_COMPRESS_MIN_TOOL_BYTES=4000
# Never compress a conversation with this many messages or fewer.
VIGIL_COMPRESS_FLOOR_MESSAGES=6
# Collapse a run of identical tool-call cycles only once it repeats this many times.
VIGIL_COMPRESS_DEDUP_MIN_RUN=3

# --- Compression Layer 2 (Token Company, optional, over HTTP) ---------------
# TTC_API_KEY=
# TTC_BASE_URL=https://api.tokencompany.ai

# --- Semantic cache / M4 (Redis LangCache, optional) ------------------------
# All three enable it. A hit serves a cached response with no upstream call; a
# miss is pure overhead, so it nets positive only above a break-even hit rate.
# REDIS_LANGCACHE_URL=
# REDIS_LANGCACHE_API_KEY=
# REDIS_LANGCACHE_CACHE_ID=
# Min cosine similarity to count as a hit (conservative avoids wrong-answer hits):
# REDIS_LANGCACHE_MIN_SIMILARITY=0.9

# --- Observability: Arize / Phoenix (optional, OTel/OpenInference) ----------
# Default backend is local Phoenix (offline-safe, no keys needed locally).
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
# PHOENIX_API_KEY=
# Optional Arize AX cloud exporter (insurance for judging):
# ARIZE_SPACE_ID=
# ARIZE_API_KEY=
# Service name attached to exported spans:
# VIGIL_TRACING_SERVICE_NAME=vigil-proxy
# Tracing requires the SDK extra: pip install -e ".[tracing]" (absent => silent no-op).

# --- Sentry (optional): agent semantic failures become Sentry Issues --------
# SENTRY_DSN=

# --- Orkes webhook (optional): POST VIGIL_BREAKER_OPEN on OPEN ---------------
# VIGIL_ORKES_WEBHOOK_URL=
